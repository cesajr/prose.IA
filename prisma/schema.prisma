generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  whatsappId    String?   @unique // ID unificado da Meta (Telefone)
  email         String?   @unique // Para o login na versão Web
  passwordHash  String?   // Nunca armazenaremos senha em texto plano
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  messages      Message[]

  @@index([whatsappId]) // Indexação para busca rápida no webhook
}

model Message {
  id        String   @id @default(uuid())
  userId    String
  role      String   // 'user' (Aluno) ou 'ai' (Tutor)
  content   String   @db.Text // Permite textos longos sem truncamento
  type      String   // 'text' ou 'audio'
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Segurança de Performance (AppSec): 
  // Sem esse índice combinado, buscar o contexto das últimas 10 mensagens 
  // para alimentar a OpenAI causaria Full Table Scan no banco à medida que o app cresce.
  @@index([userId, createdAt(sort: Desc)]) 
}